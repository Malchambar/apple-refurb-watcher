# Source ingestion
APPLE_REFURB_URL=https://www.apple.com/shop/refurbished/mac

# Alert filtering (all parsed inventory is still stored in DB)
MATCH_KEYWORDS=Mac mini,Mac Studio

# Notifications
ENABLE_PUSHOVER=true
PUSHOVER_USER_KEY=your_user_key_here
PUSHOVER_APP_TOKEN=your_app_token_here
ENABLE_IMESSAGE=false
IMESSAGE_RECIPIENT=your_apple_id_or_phone_here

# Startup + heartbeat behavior
STARTUP_NOTIFY_ENABLED=true
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_HOURS=6

# Storage + runtime
DATABASE_URL=sqlite:///data/apple_refurb_watcher.db
LOG_FILE=logs/watcher.log
REQUEST_TIMEOUT=30

# Optional behavior flags
FORCE_NOTIFY=false
TEST_MODE=false
